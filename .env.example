# Enterprise Operations Monitor — Environment Variables
# Copy this to .env and fill in your values

# ─── PostgreSQL Database ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eom_db
DB_USER=eom_user
DB_PASS=change_this_secure_password

# ─── API Configuration ─────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_string_min_16_chars
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Default Users (seeded on first start) ─────────────
DEFAULT_USERS_ENABLED=true

# ─── Backup Configuration ──────────────────────────────
BACKUP_DIR=./backups

# ─── Data Sync Pipeline ────────────────────────────────
DATA_API_URL=http://localhost:4000/api
DATA_SCHEDULER_ENABLED=false
DATA_PERSIST_ENABLED=false
DATA_EOD_POLL_MS=60000
DATA_EOD_FINAL_SYNC_TIMES=19:30,20:00,20:30,21:00,21:30

# ─── Docker Compose Only (overrides for containers) ────
# VITE_API_URL=/api                    # Frontend API base path
# DB_PORT=5432                         # Internal DB port (Docker)
