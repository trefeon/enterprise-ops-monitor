# Enterprise Operations Monitor — Environment Variables
# Copy this file to .env and replace every change_this_* value before production use.

# ─── Runtime ────────────────────────────────────────────
NODE_ENV=development
TZ=Asia/Jakarta
PORT=3000
HOSTNAME=0.0.0.0
LOG_LEVEL=info

# ─── PostgreSQL Database ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eom_db
DB_USER=eom_user
DB_PASS=change_this_secure_password
# Optional full connection URL. Docker Compose builds this automatically if omitted.
# DATABASE_URL=postgresql://eom_user:change_this_secure_password@localhost:5432/eom_db

# ─── API Security ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_16_chars
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Web Build-Time Variables (Vite) ────────────────────
# Leave VITE_API_URL empty for dev proxy, use /api for same-origin Docker/nginx proxy.
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_IT_SUPPORT_URL=
VITE_IT_SUPPORT_EMAIL=

# ─── Seed / Default Users ───────────────────────────────
# Set to true to seed demo/dummy data (stores, EOD logs, etc.) on container startup
SEED_DEMO_DATA=false
DEFAULT_USERS_ENABLED=true
DEFAULT_USERS_FORCE_PASSWORD=false
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=change_this_viewer_password
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_this_admin_password
DEFAULT_SUPERADMIN_USERNAME=superadmin
DEFAULT_SUPERADMIN_PASSWORD=change_this_superadmin_password
DEFAULT_DEMO_USERNAME=demo
DEFAULT_DEMO_PASSWORD=change_this_demo_password
# Prefer *_PASSWORD_HASH in production when available.
# DEFAULT_VIEWER_PASSWORD_HASH=
# DEFAULT_ADMIN_PASSWORD_HASH=
# DEFAULT_SUPERADMIN_PASSWORD_HASH=
# DEFAULT_DEMOADMIN_PASSWORD_HASH=
# Legacy single-admin seed support.
# ADMIN_USERNAME=
# ADMIN_PASSWORD_HASH=

# ─── Backup & Agent Updates ─────────────────────────────
BACKUP_DIR=./backups
BACKUP_CRON=05 00 * * *
BACKUP_DAILY_HHMM=00:05
BACKUP_RETENTION_DAYS=7
AGENT_UPDATE_DIR=./agent_updates

# ─── Data Sync Pipeline ────────────────────────────────
DATA_SCHEDULER_ENABLED=false
DATA_PERSIST_ENABLED=false
DATA_EOD_API_URL=https://internal-data-api.example.com/notif_eod
DATA_EMPLOYEE_API_URL=https://internal-data-api.example.com/nik_toko
DATA_SYNC_AUD_API_URL=https://internal-data-api.example.com/sync_aud
DATA_API_TIMEOUT_MS=120000
DATA_API_RETRY_ATTEMPTS=2
DATA_API_RETRY_BASE_MS=1000
DATA_API_RETRY_MAX_MS=8000
DATA_API_RETRY_JITTER_MS=250
DATA_EOD_CACHE_TTL_MS=300000
DATA_EMPLOYEE_CACHE_TTL_MS=900000
DATA_SYNC_CACHE_TTL_MS=30000
DATA_SYNC_STALE_THRESHOLD_MS=600000
DATA_EOD_POLL_MS=60000
DATA_REGULAR_POLL_MS=3600000
DATA_EMPLOYEE_DAILY_SYNC_HHMM=00:10
DATA_EMPLOYEE_REFRESH_MS=21600000
DATA_EOD_FINAL_SYNC_TIMES=19:30,20:00,20:30,21:00,21:30
DATA_SYNC_POLL_ENABLED=true
DATA_SYNC_POLL_MS=60000

# ─── After-hours Monitoring ─────────────────────────────
AFTERHOURS_ONLINE_THRESHOLD_MS=600000
AFTERHOURS_ONLINE_THRESHOLD_MS_INITIAL=600000
AFTERHOURS_ONLINE_THRESHOLD_MS_FINAL=300000
AFTERHOURS_REPORT_DAILY_HHMM=00:20

# ─── Docker Compose Notes ───────────────────────────────
# Production compose binds API/web/Postgres to localhost and uses an external DB volume.
# Create it once before first production up:
# docker volume create eom_postgres_data
