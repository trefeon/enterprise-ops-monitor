# Enterprise Operations Monitor - Environment Template
###############################################
# Copy to .env and fill in your values.

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eom_db
DB_USER=eom_user
DB_PASS=change_this_secure_password

# API Config
PORT=3000
JWT_SECRET=replace_with_at_least_16_char_random_string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash

# Default users (optional)
DEFAULT_USERS_ENABLED=true
DEFAULT_USERS_FORCE_PASSWORD=replace_with_default_user_password
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=replace_with_viewer_password
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace_with_admin_password
DEFAULT_SUPERADMIN_USERNAME=superadmin
DEFAULT_SUPERADMIN_PASSWORD=replace_with_superadmin_password

# Backup directory
BACKUP_DIR=./backups

# Data Sync Configuration (mock API URL when using demo mode)
DATA_API_URL=http://localhost:4000/api
DATA_SCHEDULER_ENABLED=false