{
  "name": "enterprise-ops-monitor",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Real-time dashboard for retail EOD processes, store sync health, and RBAC",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:mock": "node mock-api/server.js",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e:demo": "playwright test",
    "test:e2e:demo:headed": "playwright test --headed",
    "test:e2e:demo:ui": "playwright test --ui",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "check:all": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test",
    "check:deploy": "node scripts/deploy-check.js",
    "deploy": "node scripts/deploy.js",
    "deploy:demo": "node scripts/deploy.js --demo",
    "deploy:prod": "node scripts/deploy.js --prod",
    "deploy:ops": "bash scripts/deploy-ops.sh",
    "deploy:ops:demo": "bash scripts/deploy-ops.sh --host acerblue --dir /home/trefeon/dev-portfolio/enterprise-ops-monitor --mode demo-db --preserve-remote-env",
    "deploy:ops:prod": "bash scripts/deploy-ops.sh --host acerblue --dir /home/trefeon/dev-portfolio/enterprise-ops-monitor --mode prod --preserve-remote-env",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx,json,css}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/api/**/*.{js,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
